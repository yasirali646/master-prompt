# Auth (NextAuth) — required for Google/GitHub sign-in
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000

# Public site URL for SEO (canonical links, sitemap, Open Graph). Defaults to AUTH_URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MySQL — required for signed-in user data (history, settings, templates, usage, workspaces)
#
# Option A (single URL):
# DATABASE_URL=mysql://user:password@hostname:3306/database_name
#
# Option B (recommended on Hostinger + Vercel — avoids password URL-encoding issues):
# MYSQL_HOST=srv1234.hstgr.io
# MYSQL_PORT=3306
# MYSQL_USER=u366308009_masterprompt
# MYSQL_PASSWORD=your_plain_password
# MYSQL_DATABASE=u366308009_masterprompt
DATABASE_URL=

# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# Optional
RATE_LIMIT_PER_MINUTE=20

# Public site URL for SEO (canonical URLs, sitemap, Open Graph). Falls back to AUTH_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LLM API keys (OpenAI, Anthropic, Google, Groq) are NOT read from env or stored in MySQL.
# Add them in the app: Settings → API Keys (stored locally in your browser).
